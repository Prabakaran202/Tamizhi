// ----------------------------------------------------
// தமிழி HTTP லைப்ரரி (http.tz)
// ----------------------------------------------------

// சர்வரை குறிப்பிட்ட போர்ட்டில் தொடங்குகிறது
fun listen(Num port) {
    // கம்பைலர் லெவலில் உள்ள C ஃபங்ஷனை அழைக்கிறது
    __native_socket_listen(port); 
}

// கிளையண்ட் இணைப்பிற்காக காத்திருக்கிறது
fun accept_connection() {
    __native_socket_accept();
}
